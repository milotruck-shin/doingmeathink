#include <freertos/FreeRTOS.h>
#include <freertos/task.h>
#include <esp_intr_alloc.h>
#include "hal/ledc_types.h"
int PWMval;
int PWMpin=32;
int motorPWM = 21;
int motorSpeed=0;

uint16_t currentTime=0;
uint16_t prevTime=0;
float deltaT=0;
volatile uint8_t revolution=0;
uint16_t desired_RPM=0;
uint16_t actualRPM=0;
static portMUX_TYPE my_spinlock = portMUX_INITIALIZER_UNLOCKED;

ledc_timer_config_t ledc_timer = {
  .speed_mode = LEDC_LOW_SPEED_MODE,    // Low-speed mode
  .duty_resolution = LEDC_TIMER_12_BIT, // 12-bit resolution is max for 10kHz
  .timer_num = LEDC_TIMER_0,            // Timer number
  .freq_hz = 10000,                      // Frequency of the PWM signal, for example, 1000 Hz
  .clk_cfg = LEDC_AUTO_CLK              // Automatic clock source selection
};

// Initialize the configuration structure of the LEDC channel
ledc_channel_config_t ledc_channel = {
  .gpio_num   = motorPWM,
  .speed_mode = LEDC_LOW_SPEED_MODE,
  .channel    = LEDC_CHANNEL_0,
  .timer_sel  = LEDC_TIMER_0,
  .duty       = 0,  // Initial duty cycle is 0, LEDC channel duty, the range of duty setting is [0, (2**duty_resolution)]
  .hpoint     = 0  //LEDC channel hpoint value, the range is [0, (2**duty_resolution)-1]
};


ESP_ERROR_CHECK(ledc_timer_config(&ledc_timer)); // Configure PWM timer
ESP_ERROR_CHECK(ledc_channel_config(&ledc_channel)); // Initialize the LEDC channel


void setup() {
  Serial.begin(115200);
  pinMode(PWMpin,INPUT);
  attachInterrupt(digitalPinToInterrupt(PWMpin), rev_count, FALLING);  //when PWM goes from 4095 to 0 meaning from HIGH to LOW, ISR is called
  ledcSetup(ledc_channel.channel, 10000, 12);
  Serial.println("Enter desired RPM, Press ENTER");
  
  while (Serial.available() == 0) {  // Wait for input
      delay(100);  // Small delay to avoid hammering the CPU
   }
   desired_RPM = Serial.parseInt();
   Serial.println("Desired speed= " + String(desired_RPM));

   //Set motor speed
   ledc_set_duty(ledc_channel.speed_mode,ledc_channel.channel,motorSpeed); 
   ledc_update_duty(ledc_channel.speed_mode,ledc_channel.channel);
}

void loop() {
  currentTime=micros();   //record current 
  if (revolution==100){  //this value can change
     prevTime = currentTime;
    taskENTER_CRITICAL(&my_spinlock); // Disable interrupts
     currentTime=micros();  //record time again
     deltaT=(currentTime-prevTime)/1.0e6; //convert milliseconds to seconds
     actualRPM=revolution/deltaT;  //revolution per second (average speed for every 10 revolutions)
     revolution=0; //reset the value of revolutions made
    taskEXIT_CRITICAL(&my_spinlock);
  }

}

void rev_count(){ //this is the ISR
 revolution = revolution+1;
}
